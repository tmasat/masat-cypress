{
  "name": "masat-cypress",
  "version": "1.0.0",
  "description": "Run only the Cypress specs affected by your git changes",
  "main": "dist/src/cli/run.js",
  "bin": {
    "masat:cypress": "dist/bin/masat-cypress.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/bin/masat-cypress.js",
    "dev": "tsx bin/masat-cypress.ts",
    "start": "node dist/bin/masat-cypress.js",
    "prepublishOnly": "npm run build",
    "lint": "eslint 'src/**/*.ts' 'bin/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'bin/**/*.ts'"
  },
  "keywords": [
    "cypress",
    "testing",
    "cli",
    "git",
    "affected-tests"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "ts-morph": "^23.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
